<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>jp.platform.ssp</string>
    <key>CFBundleName</key>
    <string>SSP Platform</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>BGTaskSchedulerPermittedIdentifiers</key>
    <array>
        <string>jp.platform.ssp.widget-refresh</string>
    </array>
    <!-- Server URL injected via Xcode Build Settings (SSP_SERVER_URL).
         Set this in your .xcconfig or scheme's Build Settings to the
         production / staging URL before archiving. -->
    <key>SSPServerURL</key>
    <string>$(SSP_SERVER_URL)</string>
    <!-- App Groups: shared UserDefaults between main app and WidgetExtension -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.jp.platform.ssp</string>
    </array>
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <false/>
    </dict>
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>ssp</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
