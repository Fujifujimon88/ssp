# ─ コピーして .env にリネームしてください ─
DATABASE_URL=postgresql+asyncpg://ssp:ssp@localhost:5432/ssp_db
REDIS_URL=redis://localhost:6379

# 本番では必ず長いランダム文字列に変更
SECRET_KEY=change-me-in-production-use-long-random-string

APP_ENV=development
SSP_ENDPOINT=http://localhost:8000
AUCTION_TIMEOUT_MS=80
FLOOR_PRICE_DEFAULT=0.5
REVENUE_SHARE_RATE=0.70
